<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.tihu.frontend.controller.BookListDetailController"
            styleClass="card"
            prefWidth="1000" prefHeight="680">
    <top>
        <VBox styleClass="toolbar-card" spacing="8">
            <HBox spacing="10" style="-fx-alignment: center-left;">
                <Button text="返回书单列表" onAction="#onBack" styleClass="button-secondary"/>
                <Label fx:id="titleLabel" styleClass="section-title" text="书单标题"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="toggleVisibilityButton" text="切换公开/私密" onAction="#onToggleVisibility" styleClass="button-secondary"/>
            </HBox>
            <Label fx:id="ownerLabel" text="书单作者" styleClass="helper-text"/>
            <Label fx:id="visibilityLabel" text="可见性：公开" styleClass="helper-text"/>
            <Label fx:id="introLabel" text="书单简介" styleClass="helper-text"/>
        </VBox>
    </top>
    <center>
        <VBox style="-fx-padding: 16 0 0 0;" spacing="12">
            <ListView fx:id="booksListView" prefHeight="520"/>
            <HBox spacing="8">
                <TextField fx:id="bookTitleField" promptText="输入图书名称后加入" prefWidth="220"/>
                <Button fx:id="addBookButton" text="加书" onAction="#onAddBook" styleClass="button-primary"/>
                <Button fx:id="removeBookButton" text="移除选中图书" onAction="#onRemoveBook" styleClass="button-danger"/>
                <Button text="打开选中图书" onAction="#onOpenSelectedBook" styleClass="button-secondary"/>
            </HBox>
            <Label fx:id="messageLabel" styleClass="status-text"/>
        </VBox>
    </center>
</BorderPane>
