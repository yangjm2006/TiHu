<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.tihu.frontend.controller.ChatController"
            prefWidth="1000" prefHeight="680">
    <top>
        <HBox style="-fx-padding: 12; -fx-background-color: #f7f7f7;" spacing="8">
            <Button text="返回会话列表" onAction="#onBack"/>
            <Label fx:id="titleLabel" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
        </HBox>
    </top>
    <center>
        <ListView fx:id="messageListView"/>
    </center>
    <bottom>
        <VBox spacing="8" style="-fx-padding: 10;">
            <TextArea fx:id="inputArea" prefRowCount="3" wrapText="true" promptText="输入消息（纯文本）"/>
            <HBox spacing="8">
                <Button text="发送" onAction="#onSend"/>
                <Label fx:id="messageLabel" textFill="red"/>
            </HBox>
        </VBox>
    </bottom>
</BorderPane>
