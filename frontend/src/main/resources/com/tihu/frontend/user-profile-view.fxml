<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.tihu.frontend.controller.UserProfileController"
            styleClass="card"
            prefWidth="1000" prefHeight="680">
    <top>
        <VBox spacing="10" styleClass="toolbar-card">
            <Label text="用户主页" styleClass="section-title"/>
            <HBox spacing="8" style="-fx-alignment: center-left;">
                <TextField fx:id="usernameField" promptText="输入用户名" prefWidth="180"/>
                <Button text="查看主页" onAction="#onLoadProfile" styleClass="button-primary"/>
                <Button fx:id="followToggleButton" text="关注" onAction="#onToggleFollow" styleClass="button-secondary"/>
                <Button text="查看关注" onAction="#onOpenFollowing" styleClass="button-secondary"/>
                <Button text="查看粉丝" onAction="#onOpenFollowers" styleClass="button-secondary"/>
                <Button text="打开书单" onAction="#onOpenBookList" styleClass="button-secondary"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="backButton" text="返回用户管理" onAction="#onBack" styleClass="button-secondary"/>
            </HBox>
            <HBox spacing="10" style="-fx-alignment: center-left;">
                <ImageView fx:id="avatarImageView" fitWidth="64" fitHeight="64" preserveRatio="true"/>
                <VBox spacing="4">
                    <Label fx:id="userLabel" styleClass="helper-text"/>
                    <Label fx:id="relationLabel" styleClass="helper-text"/>
                </VBox>
            </HBox>
        </VBox>
    </top>
    <center>
        <SplitPane dividerPositions="0.55">
            <VBox spacing="10" style="-fx-padding: 16 14 0 0;">
                <Label text="TA 的评论列表（倒序）" styleClass="section-title"/>
                <ListView fx:id="commentsListView" prefHeight="500"/>
            </VBox>
            <VBox spacing="10" style="-fx-padding: 16 0 0 14;">
                <Label text="TA 的公开书单" styleClass="section-title"/>
                <ListView fx:id="bookListsView" prefHeight="500"/>
            </VBox>
        </SplitPane>
    </center>
    <bottom>
        <HBox style="-fx-padding: 12 4 0 4;">
            <Label fx:id="messageLabel" styleClass="error-text"/>
        </HBox>
    </bottom>
</BorderPane>
