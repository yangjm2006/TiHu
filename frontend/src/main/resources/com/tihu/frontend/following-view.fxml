<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.tihu.frontend.controller.FollowingController"
      spacing="10"
      style="-fx-padding: 24;">
    <HBox spacing="10" style="-fx-alignment: center-left;">
        <Label fx:id="titleLabel" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="countLabel"/>
    </HBox>
    <HBox spacing="8" style="-fx-alignment: center-left;">
        <Button text="关注" onAction="#onShowFollowing"/>
        <Button text="粉丝" onAction="#onShowFollowers"/>
        <TextField fx:id="keywordField" promptText="按用户名筛选" prefWidth="180" onAction="#onFilter"/>
        <Button text="筛选" onAction="#onFilter"/>
        <Button text="清空" onAction="#onClearFilter"/>
        <Button text="刷新" onAction="#onRefresh"/>
    </HBox>
    <ListView fx:id="listView" prefHeight="560"/>
    <HBox spacing="8">
        <Button text="查看主页" onAction="#onOpenProfile"/>
        <Button fx:id="followToggleButton" text="关注/取消关注" onAction="#onToggleFollow"/>
        <Label fx:id="messageLabel" textFill="red" wrapText="true"/>
    </HBox>
</VBox>
