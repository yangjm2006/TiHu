<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.tihu.frontend.controller.ProfileEditController"
      spacing="14"
      styleClass="card">
    <Label text="个人信息" styleClass="section-title"/>
    <VBox spacing="6" styleClass="panel-muted">
        <Label fx:id="currentUserLabel" styleClass="form-label"/>
        <Label fx:id="currentRoleLabel" styleClass="helper-text"/>
    </VBox>
    <GridPane styleClass="form-grid">
        <Label text="用户名：" styleClass="form-label" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <TextField fx:id="usernameField" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
        <Label text="新密码：" styleClass="form-label" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <PasswordField fx:id="passwordField" promptText="不改可留空" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
    </GridPane>
    <Button text="保存修改" onAction="#onSave" styleClass="button-primary"/>
    <Label fx:id="messageLabel" wrapText="true" styleClass="status-text"/>
</VBox>
