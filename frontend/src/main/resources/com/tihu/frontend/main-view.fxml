<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.tihu.frontend.Controller.MainController"
            prefWidth="900" prefHeight="600">

    <!-- 顶部：标题 + 搜索 -->
    <top>
        <HBox spacing="10" style="-fx-padding: 10; -fx-background-color: #f0f0f0;">
            <Label text="TiHu" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <TextField fx:id="searchField" promptText="搜索图书/电影" prefWidth="260"/>
            <Button text="搜索" onAction="#onSearch"/>
        </HBox>
    </top>

    <!-- 左侧导航 -->
    <left>
        <VBox spacing="8" style="-fx-padding: 10; -fx-background-color: #fafafa;" prefWidth="160">
            <Button text="首页" onAction="#onHome"/>
            <Button text="图书" onAction="#onBooks"/>
            <Button text="电影" onAction="#onMovies"/>
            <Button text="讨论区" onAction="#onForum"/>
            <Button text="我的" onAction="#onProfile"/>
        </VBox>
    </left>

    <!-- 中间内容区域 -->
    <center>
        <StackPane fx:id="contentPane">
            <Label text="欢迎来到 TiHu" style="-fx-font-size: 16px;"/>
        </StackPane>
    </center>
</BorderPane>