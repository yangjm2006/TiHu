<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.tihu.frontend.controller.ProfileEditController"
      spacing="10"
      style="-fx-padding: 24;">
    <Label text="个人信息" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
    <GridPane hgap="8" vgap="8">
        <Label text="用户名：" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <TextField fx:id="usernameField" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
        <Label text="新密码：" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <PasswordField fx:id="passwordField" promptText="不改可留空" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
    </GridPane>
    <Button text="保存修改" onAction="#onSave"/>
    <Label fx:id="messageLabel" wrapText="true"/>
</VBox>
