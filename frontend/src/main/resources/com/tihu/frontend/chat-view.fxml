<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.tihu.frontend.controller.ChatController"
            styleClass="card"
            prefWidth="1000" prefHeight="680">
    <top>
        <HBox styleClass="toolbar-card" spacing="10">
            <Button text="返回会话列表" onAction="#onBack" styleClass="button-secondary"/>
            <Label fx:id="titleLabel" styleClass="section-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="查看主页" onAction="#onOpenPeerProfile" styleClass="button-secondary"/>
            <Button text="刷新" onAction="#onRefresh" styleClass="button-info"/>
        </HBox>
    </top>
    <center>
        <ListView fx:id="messageListView"/>
    </center>
    <bottom>
        <VBox spacing="10" style="-fx-padding: 14 0 0 0;">
            <TextArea fx:id="inputArea" prefRowCount="3" wrapText="true" promptText="输入消息（纯文本）"/>
            <HBox spacing="8">
                <Button text="发送" onAction="#onSend" styleClass="button-primary"/>
                <Label fx:id="messageLabel" styleClass="error-text"/>
            </HBox>
        </VBox>
    </bottom>
</BorderPane>
