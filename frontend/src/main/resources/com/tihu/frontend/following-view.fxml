<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.tihu.frontend.controller.FollowingController"
      spacing="12"
      styleClass="card">
    <HBox spacing="10" style="-fx-alignment: center-left;">
        <Label fx:id="titleLabel" styleClass="section-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="countLabel" styleClass="status-text"/>
    </HBox>
    <HBox spacing="8" style="-fx-alignment: center-left;">
        <Button text="关注" onAction="#onShowFollowing" styleClass="button-secondary"/>
        <Button text="粉丝" onAction="#onShowFollowers" styleClass="button-secondary"/>
        <TextField fx:id="keywordField" promptText="按用户名筛选" prefWidth="180" onAction="#onFilter"/>
        <Button text="筛选" onAction="#onFilter" styleClass="button-primary"/>
        <Button text="清空" onAction="#onClearFilter" styleClass="button-secondary"/>
        <Button text="刷新" onAction="#onRefresh" styleClass="button-info"/>
    </HBox>
    <ListView fx:id="listView" prefHeight="560"/>
    <HBox spacing="8">
        <Button text="查看主页" onAction="#onOpenProfile" styleClass="button-primary"/>
        <Button fx:id="followToggleButton" text="关注/取消关注" onAction="#onToggleFollow" styleClass="button-secondary"/>
        <Label fx:id="messageLabel" styleClass="error-text" wrapText="true"/>
    </HBox>
</VBox>
