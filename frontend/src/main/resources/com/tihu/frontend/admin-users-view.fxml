<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.tihu.frontend.controller.AdminUsersController"
      spacing="12"
      styleClass="card">
    <Label text="用户管理 - 封禁/解封" styleClass="section-title"/>
    <HBox spacing="8">
        <TextField fx:id="usernameField" promptText="用户名"/>
        <TextField fx:id="hoursField" promptText="封禁小时数（如24）"/>
        <Button text="封禁" onAction="#onBan" styleClass="button-danger"/>
        <Button text="解除封禁" onAction="#onUnban" styleClass="button-secondary"/>
    </HBox>
    <Label text="被封禁用户列表（按解封时间排序，选中后可直接解除封禁）：" styleClass="helper-text"/>
    <ListView fx:id="bannedListView" prefHeight="480"/>
    <Label fx:id="messageLabel" styleClass="error-text" wrapText="true"/>
</VBox>

