<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.tihu.frontend.controller1.MainController"
            prefWidth="900" prefHeight="600">

    <top>
        <HBox spacing="10" style="-fx-padding: 10; -fx-background-color: #f0f0f0; -fx-alignment: center-left;">
            <Label text="TiHu" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <TextField fx:id="searchField" promptText="搜索图书 / 作者" prefWidth="260"/>
            <Button text="搜索" onAction="#onSearch"/>
        </HBox>
    </top>

    <left>
        <VBox spacing="8" style="-fx-padding: 10; -fx-background-color: #fafafa;" prefWidth="160">
            <Button text="首页" onAction="#onHome"/>
            <Button text="图书" onAction="#onBooks"/>
            <Button text="电影" onAction="#onMovies"/>
            <Button text="讨论区" onAction="#onForum"/>
            <Button text="我的" onAction="#onProfile"/>
        </VBox>
    </left>

    <center>
        <StackPane fx:id="contentPane" style="-fx-background-color: white;"/>
    </center>

    <bottom>
        <HBox style="-fx-padding: 8 12; -fx-background-color: #fafafa;">
            <Label text="图书评论打分系统"/>
        </HBox>
    </bottom>
</BorderPane>