<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.tihu.frontend.controller.FollowingController"
      spacing="10"
      style="-fx-padding: 24;">
    <Label fx:id="titleLabel" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
    <ListView fx:id="listView" prefHeight="500"/>
    <HBox spacing="8">
        <Button text="查看主页" onAction="#onOpenProfile"/>
        <Button fx:id="followToggleButton" text="关注/取关" onAction="#onToggleFollow"/>
        <Label fx:id="messageLabel" textFill="red" wrapText="true"/>
    </HBox>
</VBox>
