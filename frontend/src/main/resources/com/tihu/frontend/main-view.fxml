<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.tihu.frontend.controller.MainController"
            styleClass="app-root"
            prefWidth="1220" prefHeight="760">

    <top>
        <HBox styleClass="topbar">
            <Label text="TiHu" styleClass="brand-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <TextField fx:id="searchField" promptText="搜索书名" prefWidth="220"/>
            <Button text="搜索" onAction="#onSearch" styleClass="button-primary"/>
            <Label fx:id="userLabel" styleClass="status-text"/>
            <Button text="退出登录" onAction="#onLogout" styleClass="button-secondary"/>
        </HBox>
    </top>

    <left>
        <VBox styleClass="sidebar" prefWidth="210">
            <Button text="首页" onAction="#onHome" styleClass="nav-item"/>
            <Button text="图书" onAction="#onBooks" styleClass="nav-item"/>
            <Button text="我的收藏" onAction="#onFavorites" styleClass="nav-item"/>
            <Button text="我的书单" onAction="#onBookLists" styleClass="nav-item"/>
            <Button text="用户主页" onAction="#onUserProfile" styleClass="nav-item"/>
            <Button text="个人信息" onAction="#onProfileEdit" styleClass="nav-item"/>
            <Button text="关注列表" onAction="#onFollowing" styleClass="nav-item"/>
            <Button text="粉丝列表" onAction="#onFollowers" styleClass="nav-item"/>
            <Button text="私信会话" onAction="#onConversations" styleClass="nav-item"/>
            <Separator/>
            <Label text="管理员" fx:id="adminLabel" styleClass="nav-section"/>
            <VBox fx:id="adminBox" spacing="8">
                <Button text="图书管理" onAction="#onAdminBooks" styleClass="nav-item"/>
                <Button text="用户封禁" onAction="#onAdminUsers" styleClass="nav-item"/>
                <Button text="评论管理" onAction="#onAdminComments" styleClass="nav-item"/>
            </VBox>
        </VBox>
    </left>

    <center>
        <StackPane fx:id="contentPane" styleClass="page-content"/>
    </center>

</BorderPane>
