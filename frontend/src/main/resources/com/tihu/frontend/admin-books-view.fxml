<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.tihu.frontend.controller.AdminBooksController"
            prefWidth="1000" prefHeight="680">
    <left>
        <VBox spacing="8" style="-fx-padding: 12;" prefWidth="420">
            <Label text="图书管理" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
            <TextField fx:id="titleField" promptText="书名（必填且唯一）"/>
            <TextField fx:id="authorField" promptText="作者"/>
            <TextField fx:id="tagsField" promptText="标签，逗号分隔"/>
            <TextArea fx:id="introArea" promptText="简介" prefRowCount="5" wrapText="true"/>
            <HBox spacing="8">
                <Button text="新增图书" onAction="#onAddBook"/>
                <Button text="更新选中图书" onAction="#onUpdateBook"/>
                <Button text="删除选中" onAction="#onDeleteBook"/>
            </HBox>
            <Label fx:id="messageLabel" wrapText="true"/>
        </VBox>
    </left>
    <center>
        <TableView fx:id="tableView" columnResizePolicy="CONSTRAINED_RESIZE_POLICY_FLEX_LAST_COLUMN">
            <columns>
                <TableColumn fx:id="titleColumn" text="书名"/>
                <TableColumn fx:id="authorColumn" text="作者"/>
                <TableColumn fx:id="ratingColumn" text="评分"/>
            </columns>
        </TableView>
    </center>
</BorderPane>

