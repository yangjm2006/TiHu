<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.tihu.frontend.controller.AdminBooksController"
            styleClass="card"
            prefWidth="1000" prefHeight="680">
    <top>
        <VBox spacing="10" styleClass="toolbar-card" style="-fx-padding: 14 16;">
            <Label text="图书管理" styleClass="section-title"/>
            <HBox spacing="8" style="-fx-alignment: center-left;">
                <TextField fx:id="searchTitleField" promptText="按书名搜索" prefWidth="220"/>
                <TextField fx:id="searchTagsField" promptText="按标签搜索，空格分隔" prefWidth="250"/>
                <Button text="搜索" onAction="#onSearch" styleClass="button-primary"/>
                <Button text="重置" onAction="#onResetSearch" styleClass="button-secondary"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="排序：" styleClass="form-label"/>
                <ComboBox fx:id="sortBox" prefWidth="150"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <SplitPane dividerPositions="0.66" style="-fx-padding: 14 0 0 0;">
            <BorderPane>
                <center>
                    <TableView fx:id="tableView">
                        <columns>
                            <TableColumn fx:id="titleColumn" text="书名" prefWidth="230"/>
                            <TableColumn fx:id="authorColumn" text="作者" prefWidth="150"/>
                            <TableColumn fx:id="ratingColumn" text="评分" prefWidth="90"/>
                            <TableColumn fx:id="tagsColumn" text="标签摘要" prefWidth="230"/>
                        </columns>
                    </TableView>
                </center>
                <bottom>
                    <HBox spacing="8" style="-fx-padding: 12 0 0 0; -fx-alignment: center-right;">
                        <Label fx:id="pageInfoLabel" text="第 1/1 页" styleClass="status-text"/>
                        <Button text="上一页" onAction="#onPrevPage" styleClass="button-secondary"/>
                        <Button text="下一页" onAction="#onNextPage" styleClass="button-secondary"/>
                    </HBox>
                </bottom>
            </BorderPane>

            <VBox spacing="12" styleClass="toolbar-card" minWidth="300" prefWidth="330">
                <Label text="编辑图书" styleClass="section-title"/>

                <VBox spacing="6">
                    <Label text="书名" styleClass="form-label"/>
                    <TextField fx:id="titleField" promptText="书名（必填且唯一）"/>
                </VBox>

                <VBox spacing="6">
                    <Label text="作者" styleClass="form-label"/>
                    <TextField fx:id="authorField" promptText="作者"/>
                </VBox>

                <VBox spacing="6">
                    <Label text="标签" styleClass="form-label"/>
                    <TextField fx:id="tagsField" promptText="标签，空格分隔"/>
                </VBox>

                <VBox spacing="6">
                    <Label text="简介" styleClass="form-label"/>
                    <TextArea fx:id="introArea" promptText="简介" prefRowCount="5" wrapText="true"/>
                </VBox>

                <HBox spacing="10" style="-fx-alignment: center-left;">
                    <ImageView fx:id="coverPreview" fitWidth="86" fitHeight="116" preserveRatio="true"/>
                    <VBox spacing="8">
                        <Button text="上传封面" onAction="#onUploadCover" styleClass="button-secondary" maxWidth="Infinity"/>
                        <Button text="清空封面" onAction="#onClearCover" styleClass="button-secondary" maxWidth="Infinity"/>
                        <Label fx:id="coverStatusLabel" text="当前无封面" styleClass="helper-text" wrapText="true"/>
                    </VBox>
                </HBox>

                <HBox spacing="8" style="-fx-alignment: center-left;">
                    <Button text="新增" onAction="#onAddBook" styleClass="button-primary"/>
                    <Button text="更新" onAction="#onUpdateBook" styleClass="button-secondary"/>
                    <Button text="删除" onAction="#onDeleteBook" styleClass="button-danger"/>
                </HBox>

                <Label fx:id="messageLabel" wrapText="true" styleClass="status-text"/>
            </VBox>
        </SplitPane>
    </center>
</BorderPane>
