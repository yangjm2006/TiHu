<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.tihu.frontend.controller.BookDetailController"
            prefWidth="980" prefHeight="720">

    <top>
        <VBox spacing="8" style="-fx-padding: 14; -fx-background-color: #f5f5f5;">
            <HBox spacing="10">
                <Button text="← 返回列表" onAction="#onBackToBooks"/>
                <Label fx:id="titleLabel" text="图书标题" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
            </HBox>
            <Label fx:id="metaLabel" text="作者 / 年份 / 评分 / 分类"/>
        </VBox>
    </top>

    <center>
        <SplitPane dividerPositions="0.52">
            <VBox spacing="10" style="-fx-padding: 14;">
                <Label text="简介" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                <TextArea fx:id="descArea"
                          editable="false"
                          wrapText="true"
                          prefHeight="260"
                          promptText="这里显示图书简介"/>

                <Label text="评分汇总" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                <Label fx:id="ratingSummaryLabel" text="平均分：暂无评分"/>
                <TextArea fx:id="distributionArea"
                          editable="false"
                          wrapText="true"
                          prefRowCount="10"
                          promptText="评分分布"/>

                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="我的评分："/>
                    <Spinner fx:id="myScoreSpinner" prefWidth="120"/>
                    <Button text="提交评分" onAction="#onRate"/>
                </HBox>
            </VBox>

            <VBox spacing="10" style="-fx-padding: 14;">
                <Label text="评论" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                <ListView fx:id="commentListView" prefHeight="280"/>

                <HBox spacing="8">
                    <Button text="回复选中" onAction="#onReplySelected"/>
                    <Button text="删除/撤回" onAction="#onDeleteOwnComment"/>
                    <Button text="赞" onAction="#onUpVote"/>
                    <Button text="踩" onAction="#onDownVote"/>
                </HBox>

                <Label text="发表短评" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
                <TextArea fx:id="commentInputArea"
                          promptText="写下你的评论..."
                          wrapText="true"
                          prefRowCount="4"/>

                <HBox spacing="10">
                    <Button text="提交评论" onAction="#onSubmitComment"/>
                    <Button text="收藏" onAction="#onCollect"/>
                    <Label fx:id="messageLabel" text="" wrapText="true"/>
                </HBox>
            </VBox>
        </SplitPane>
    </center>

    <bottom>
        <HBox spacing="10" style="-fx-padding: 10 14; -fx-background-color: #fafafa;">
            <Label text="提示：选中评论后可回复、删除/撤回或进行点赞点踩"/>
        </HBox>
    </bottom>
</BorderPane>
