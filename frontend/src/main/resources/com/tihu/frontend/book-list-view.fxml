<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            xmlns="http://javafx.com/javafx"
            fx:controller="com.tihu.frontend.controller.BookListController"
            styleClass="card"
            prefWidth="1000" prefHeight="680">
    <top>
        <VBox spacing="10" styleClass="toolbar-card">
            <Label text="图书列表" styleClass="section-title"/>
            <HBox spacing="10">
                <TextField fx:id="titleSearchField" promptText="按书名模糊搜索" prefWidth="220"/>
                <TextField fx:id="tagsSearchField" promptText="按标签 AND 搜索，例如：科幻 宇宙" prefWidth="280"/>
                <Button text="搜索" onAction="#onSearch" styleClass="button-primary"/>
                <Button text="重置" onAction="#onReset" styleClass="button-secondary"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="排序：" styleClass="form-label"/>
                <ComboBox fx:id="sortBox" prefWidth="170"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <TableView fx:id="bookTableView">
            <columns>
                <TableColumn fx:id="titleColumn" text="书名" prefWidth="220"/>
                <TableColumn fx:id="authorColumn" text="作者" prefWidth="180"/>
                <TableColumn fx:id="ratingColumn" text="平均评分" prefWidth="130"/>
                <TableColumn fx:id="tagsColumn" text="标签摘要" prefWidth="320"/>
            </columns>
        </TableView>
    </center>

    <bottom>
        <HBox spacing="8" style="-fx-padding: 14 4 0 4; -fx-alignment: center-right;">
            <Label fx:id="pageInfoLabel" text="第 1/1 页" styleClass="status-text"/>
            <Button text="上一页" onAction="#onPrevPage" styleClass="button-secondary"/>
            <Button text="下一页" onAction="#onNextPage" styleClass="button-secondary"/>
            <Button text="查看详情" onAction="#onOpenDetail" styleClass="button-primary"/>
        </HBox>
    </bottom>
</BorderPane>
